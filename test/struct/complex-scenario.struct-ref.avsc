{
  "type": "record",
  "name": "ComplexScenario",
  "doc": "Complex test scenario combining multiple JSON Structure features",
  "fields": [
    {
      "name": "metadata",
      "type": {
        "type": "record",
        "name": "MetadataType",
        "fields": [
          {
            "name": "id",
            "type": {
              "type": "string",
              "logicalType": "uuid"
            },
            "doc": "Unique identifier"
          },
          {
            "name": "version",
            "type": "string",
            "doc": "Semantic version [pattern: ^\\d+\\.\\d+\\.\\d+$]"
          },
          {
            "name": "created",
            "type": {
              "type": "string",
              "logicalType": "rfc3339-timestamp-millis"
            },
            "doc": "Creation timestamp"
          },
          {
            "name": "tags",
            "type": [
              "null",
              {
                "type": "array",
                "items": "string"
              }
            ],
            "default": null
          }
        ]
      }
    },
    {
      "name": "data",
      "type": {
        "type": "record",
        "name": "Choice_measurement_event",
        "doc": "Tagged union with explicit discriminator",
        "fields": [
          {
            "name": "choiceType",
            "type": {
              "type": "enum",
              "name": "Choice_measurement_eventType",
              "symbols": [
                "measurement",
                "event"
              ]
            },
            "doc": "Discriminator indicating which type is present in the value field"
          },
          {
            "name": "value",
            "type": [
              {
                "type": "record",
                "name": "AnonymousObject1",
                "fields": [
                  {
                    "name": "type",
                    "type": "string"
                  },
                  {
                    "name": "value",
                    "type": {
                      "type": "string",
                      "logicalType": "decimal"
                    },
                    "doc": "[precision: 15, scale: 6]"
                  },
                  {
                    "name": "timestamp",
                    "type": {
                      "type": "string",
                      "logicalType": "rfc3339-timestamp-millis"
                    }
                  },
                  {
                    "name": "device",
                    "type": [
                      "null",
                      {
                        "type": "record",
                        "name": "DeviceType",
                        "fields": [
                          {
                            "name": "id",
                            "type": "string"
                          },
                          {
                            "name": "calibration",
                            "type": [
                              "null",
                              {
                                "type": "map",
                                "values": "double"
                              }
                            ],
                            "default": null
                          }
                        ]
                      }
                    ],
                    "default": null
                  }
                ]
              },
              {
                "type": "record",
                "name": "AnonymousObject2",
                "fields": [
                  {
                    "name": "type",
                    "type": "string"
                  },
                  {
                    "name": "name",
                    "type": "string"
                  },
                  {
                    "name": "severity",
                    "type": "string"
                  },
                  {
                    "name": "details",
                    "type": [
                      "null",
                      {
                        "type": "array",
                        "items": {
                          "type": "record",
                          "name": "DetailsType",
                          "fields": [
                            {
                              "name": "key",
                              "type": "string"
                            },
                            {
                              "name": "value",
                              "type": [
                                "string",
                                "long",
                                "double",
                                "boolean"
                              ]
                            }
                          ]
                        }
                      }
                    ],
                    "default": null
                  }
                ]
              }
            ],
            "doc": "The actual value of the selected choice type"
          }
        ]
      }
    },
    {
      "name": "signature",
      "type": [
        "null",
        "bytes"
      ],
      "doc": "Digital signature",
      "default": null
    }
  ]
}
