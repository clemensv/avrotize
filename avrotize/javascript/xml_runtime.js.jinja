/* XML serialization support generated by Avrotize. */
'use strict';

const zlib = require('zlib');
const { XMLBuilder, XMLParser } = require('fast-xml-parser');

const XML_OPTIONS = Object.freeze({
    ignoreAttributes: false,
    attributeNamePrefix: '@_',
    parseTagValue: false,
    parseAttributeValue: false,
    trimValues: false,
    processEntities: false,
    allowBooleanAttributes: true,
    suppressBooleanAttributes: false
});

function contentTypeInfo(contentType) {
    let mediaType = String(contentType || 'application/json').split(';', 1)[0].trim().toLowerCase();
    const gzip = mediaType.endsWith('+gzip');
    if (gzip) mediaType = mediaType.slice(0, -5);
    return { mediaType, gzip };
}

function isXml(mediaType) {
    return mediaType === 'application/xml' || mediaType === 'text/xml' || mediaType.endsWith('+xml');
}

function enumToWire(value, type) {
    const key = String(value);
    return Object.prototype.hasOwnProperty.call(type.values || {}, key) ? type.values[key] : key;
}

function enumFromWire(value, type) {
    const wire = String(value);
    for (const [key, mapped] of Object.entries(type.values || {})) {
        if (String(mapped) === wire) return key;
    }
    return wire;
}

function selectUnionType(value, choices) {
    if (value === null || value === undefined) return choices.find((t) => t.kind === 'null') || choices[0];
    if (Array.isArray(value)) return choices.find((t) => t.kind === 'array') || choices[0];
    if (value instanceof Set) return choices.find((t) => t.kind === 'set') || choices[0];
    for (const type of choices) {
        if (type.kind === 'record' && type.ctor && value instanceof type.ctor) return type;
        if (type.kind === 'enum' && Object.prototype.hasOwnProperty.call(type.values || {}, String(value))) return type;
        if (type.kind === 'number' && typeof value === 'number') return type;
        if (type.kind === 'boolean' && typeof value === 'boolean') return type;
        if (type.kind === 'bigint' && typeof value === 'bigint') return type;
        if (type.kind === 'string' && typeof value === 'string') return type;
        if ((type.kind === 'map' || type.kind === 'any') && typeof value === 'object') return type;
    }
    return choices.find((t) => t.kind !== 'null') || choices[0];
}

function toAnyXml(value) {
    if (value === null || value === undefined) return '';
    if (value instanceof Date) return value.toISOString();
    if (Array.isArray(value)) return { item: value.map(toAnyXml) };
    if (value instanceof Set) return { item: Array.from(value, toAnyXml) };
    if (typeof value === 'object') {
        const result = {};
        for (const [key, child] of Object.entries(value)) result[key] = toAnyXml(child);
        return result;
    }
    return value;
}

function toXmlValue(value, type) {
    if (value === null || value === undefined) return undefined;
    switch (type.kind) {
        case 'record': return toXmlBody(value, type.ctor.XmlMapping);
        case 'enum': return enumToWire(value, type);
        case 'date': return value instanceof Date ? value.toISOString() : String(value);
        case 'bigint': return String(value);
        case 'array': return { item: value.map((item) => toXmlValue(item, type.items)) };
        case 'set': return { item: Array.from(value, (item) => toXmlValue(item, type.items)) };
        case 'map': return {
            entry: Object.entries(value).map(([key, item]) => ({
                '@_key': key,
                value: toXmlValue(item, type.values)
            }))
        };
        case 'union': {
            const selected = selectUnionType(value, type.choices);
            const nonNull = type.choices.filter((choice) => choice.kind !== 'null');
            if (nonNull.length <= 1) return toXmlValue(value, selected);
            return { '@_union': String(type.choices.indexOf(selected)), value: toXmlValue(value, selected) };
        }
        case 'any': return toAnyXml(value);
        default: return value;
    }
}

function toXmlBody(value, mapping) {
    const result = {};
    if (mapping.namespace) result['@_xmlns'] = mapping.namespace;
    for (const [property, field] of Object.entries(mapping.fields)) {
        const child = value[property];
        if (child === undefined) continue;
        if (child === null) {
            if (field.kind !== 'attribute') result[field.name] = { '@_xsi:nil': 'true', '@_xmlns:xsi': 'http://www.w3.org/2001/XMLSchema-instance' };
            continue;
        }
        const encoded = toXmlValue(child, field.type);
        result[field.kind === 'attribute' ? `@_${field.name}` : field.name] = encoded;
    }
    return result;
}

function coercePrimitive(value, kind) {
    if (kind === 'string') return String(value ?? '');
    if (kind === 'number') return Number(value);
    if (kind === 'boolean') return value === true || String(value).toLowerCase() === 'true' || String(value) === '1';
    if (kind === 'bigint') return BigInt(value);
    if (kind === 'date') return new Date(String(value));
    if (kind === 'null') return null;
    return value;
}

function fromXmlValue(value, type) {
    if (value && typeof value === 'object' && String(value['@_xsi:nil']).toLowerCase() === 'true') return null;
    switch (type.kind) {
        case 'record': return fromXmlBody(value || {}, type.ctor.XmlMapping);
        case 'enum': return enumFromWire(value, type);
        case 'array': {
            if (value === '' || value === null || value === undefined) return [];
            const items = typeof value === 'object' ? value.item : [];
            if (items === undefined || items === '') return [];
            return (Array.isArray(items) ? items : [items]).map((item) => fromXmlValue(item, type.items));
        }
        case 'set': {
            const array = fromXmlValue(value, { kind: 'array', items: type.items });
            return new Set(array);
        }
        case 'map': {
            if (value === '' || value === null || value === undefined) return {};
            const rawEntries = typeof value === 'object' ? value.entry : [];
            const entries = rawEntries === undefined || rawEntries === '' ? [] : (Array.isArray(rawEntries) ? rawEntries : [rawEntries]);
            const result = {};
            for (const entry of entries) result[String(entry['@_key'])] = fromXmlValue(entry.value, type.values);
            return result;
        }
        case 'union': {
            const nonNull = type.choices.filter((choice) => choice.kind !== 'null');
            if (value === null || value === undefined) return null;
            if (typeof value === 'object' && Object.prototype.hasOwnProperty.call(value, '@_union')) {
                const selected = type.choices[Number(value['@_union'])];
                if (!selected) throw new Error(`Invalid XML union branch '${value['@_union']}'`);
                return fromXmlValue(value.value, selected);
            }
            if (typeof value === 'object') {
                const record = nonNull.find((choice) => choice.kind === 'record');
                if (record) return fromXmlValue(value, record);
                const collection = nonNull.find((choice) => ['array', 'set', 'map'].includes(choice.kind));
                if (collection) return fromXmlValue(value, collection);
            }
            const enumType = nonNull.find((choice) => choice.kind === 'enum' && Object.values(choice.values || {}).map(String).includes(String(value)));
            return fromXmlValue(value, enumType || nonNull[0] || { kind: 'any' });
        }
        default: return coercePrimitive(value, type.kind);
    }
}

function fromXmlBody(body, mapping) {
    const instance = new mapping.ctor();
    for (const [property, field] of Object.entries(mapping.fields)) {
        const key = field.kind === 'attribute' ? `@_${field.name}` : field.name;
        if (Object.prototype.hasOwnProperty.call(body, key)) instance[property] = fromXmlValue(body[key], field.type);
    }
    return instance;
}

function toPlainValue(value, type) {
    if (value === null || value === undefined) return value;
    switch (type.kind) {
        case 'record': return toPlainBody(value, type.ctor.XmlMapping);
        case 'array': return value.map((item) => toPlainValue(item, type.items));
        case 'set': return Array.from(value, (item) => toPlainValue(item, type.items));
        case 'map': return Object.fromEntries(Object.entries(value).map(([key, item]) => [key, toPlainValue(item, type.values)]));
        case 'union': return toPlainValue(value, selectUnionType(value, type.choices));
        case 'date': return value instanceof Date ? value.toISOString() : value;
        case 'bigint': return String(value);
        default: return value;
    }
}

function toPlainBody(value, mapping) {
    const result = {};
    for (const [property, field] of Object.entries(mapping.fields)) {
        if (value[property] !== undefined) result[property] = toPlainValue(value[property], field.type);
    }
    return result;
}

function fromPlainValue(value, type) {
    if (value === null || value === undefined) return value;
    switch (type.kind) {
        case 'record': return fromPlainBody(value, type.ctor.XmlMapping);
        case 'array': return value.map((item) => fromPlainValue(item, type.items));
        case 'set': return new Set(Array.from(value, (item) => fromPlainValue(item, type.items)));
        case 'map': return Object.fromEntries(Object.entries(value).map(([key, item]) => [key, fromPlainValue(item, type.values)]));
        case 'union': return fromPlainValue(value, selectUnionType(value, type.choices));
        case 'date': return new Date(value);
        case 'bigint': return BigInt(value);
        default: return value;
    }
}

function fromPlainBody(body, mapping) {
    const instance = new mapping.ctor();
    for (const [property, field] of Object.entries(mapping.fields)) {
        if (Object.prototype.hasOwnProperty.call(body, property)) instance[property] = fromPlainValue(body[property], field.type);
    }
    return instance;
}

function toByteArray(value, mapping, contentType, avroType) {
    const { mediaType, gzip } = contentTypeInfo(contentType);
    let result;
    if (isXml(mediaType)) {
        const document = { [mapping.name]: toXmlBody(value, mapping) };
        result = Buffer.from(new XMLBuilder(XML_OPTIONS).build(document), 'utf8');
    } else if (mediaType === 'application/json' || mediaType === 'avro/json' || mediaType.endsWith('+json')) {
        result = Buffer.from(JSON.stringify(toPlainBody(value, mapping)), 'utf8');
    } else if (avroType && (mediaType === 'avro/binary' || mediaType === 'application/vnd.apache.avro+avro')) {
        result = avroType.toBuffer(toPlainBody(value, mapping));
    } else {
        throw new TypeError(`Unsupported media type: ${mediaType}`);
    }
    return gzip ? zlib.gzipSync(result) : result;
}

function fromData(data, mapping, contentType, avroType) {
    if (data === null || data === undefined) return null;
    if (data instanceof mapping.ctor) return data;
    const { mediaType, gzip } = contentTypeInfo(contentType);
    let bytes = Buffer.isBuffer(data) ? data : Buffer.from(data);
    if (gzip) bytes = zlib.gunzipSync(bytes);
    if (isXml(mediaType)) {
        const document = new XMLParser(XML_OPTIONS).parse(bytes.toString('utf8'));
        const body = document[mapping.name];
        if (body === undefined) throw new Error(`Expected XML root element '${mapping.name}'`);
        return fromXmlBody(body || {}, mapping);
    }
    if (mediaType === 'application/json' || mediaType === 'avro/json' || mediaType.endsWith('+json')) {
        return fromPlainBody(JSON.parse(bytes.toString('utf8')), mapping);
    }
    if (avroType && (mediaType === 'avro/binary' || mediaType === 'application/vnd.apache.avro+avro')) {
        return fromPlainBody(avroType.fromBuffer(bytes), mapping);
    }
    throw new TypeError(`Unsupported media type: ${mediaType}`);
}

module.exports = { XML_OPTIONS, toByteArray, fromData };
