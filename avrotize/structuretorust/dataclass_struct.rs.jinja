#[derive(Debug{%- if serde_annotation %}, Serialize, Deserialize{%- endif %}, PartialEq, Clone, Default)]
pub struct {{ struct_name }} {
{%- for field in fields %}
    {%- if field.serde_rename and serde_annotation %}
