from enum import {% if is_numeric %}IntEnum{% else %}Enum{% endif %}


class {{ class_name }}({% if is_numeric %}IntEnum{% else %}Enum{% endif %}):
    """
    {{ docstring }}
    """
    {%- for member_name, value_repr in members %}
    {{ member_name }} = {{ value_repr }}
    {%- endfor %}

    {%- if xml_annotation %}

    @classmethod
    def xml_name(cls) -> str:
        """Return the schema's XML type name."""
        return {{ xml_name | tojson }}

    @property
    def xml_value(self) -> str:
        """Return this member's XML wire value."""
        {%- for member_name, xml_value_literal in xml_values %}
        if self is {{ class_name }}.{{ member_name }}:
            return {{ xml_value_literal }}
        {%- endfor %}
        return str(self.value)

    @classmethod
    def from_xml_value(cls, value: str) -> '{{ class_name }}':
        """Resolve an enum member from its XML wire value."""
        {%- for member_name, xml_value_literal in xml_values %}
        if value == str({{ xml_value_literal }}):
            return cls.{{ member_name }}
        {%- endfor %}
        return cls(value)
    {%- endif %}

    @classmethod
    def from_ordinal(cls, ordinal: int | str) -> '{{ class_name }}':
        """
        Get enum member by ordinal

        Args:
            ordinal (int | str): The ordinal of the enum member. This can be an integer or a string representation of an integer.

        Returns:
            The enum member corresponding to the ordinal.
        """
        if ordinal is None:
            raise ValueError("ordinal must not be None")
        if isinstance(ordinal, str) and ordinal.isdigit():
            ordinal = int(ordinal)
        members = list(cls)
        if 0 <= int(ordinal) < len(members):
            return members[ordinal]
        else:
            raise IndexError("Ordinal out of range for enum")

    @classmethod
    def to_ordinal(cls, member: '{{ class_name }}') -> int:
        """
        Get enum ordinal

        Args:
            member ({{ class_name }}): The enum member to get the ordinal of.

        Returns:
            The ordinal of the enum member.
        """
        members = list(cls)
        return members.index(member)
